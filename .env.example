PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:4200,http://localhost:3001

# Polymarket - RTDS
POLYMARKET_RTDS_URL=wss://ws-live-data.polymarket.com

# Polymarket - CLOB WebSocket
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Polymarket - REST APIs
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com

# Default subscriptions (comma-separated, loaded at startup)
POLYMARKET_DEFAULT_CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT

# Edge detection — trade advice tuning
# Minimum absolute probability gap between Deribit and Polymarket
# needed to emit BUY_YES / BUY_NO advice. 0.08 = 8%.
ARBITRAGE_EDGE_THRESHOLD=0.08

# How often (ms) to REST-refresh Polymarket orderbooks as a safety net
# for missed CLOB WebSocket book updates.
BOOK_REFRESH_MS=10000

# Trailing-edge throttle (ms) per market for edge recalculation after
# CLOB book updates. Prevents bursty orderbook deltas from flooding
# the SSE stream.
BOOK_THROTTLE_MS=500

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Deribit
DERIBIT_WS_URL=wss://www.deribit.com/ws/api/v2
DERIBIT_INSTRUMENTS=BTC-PERPETUAL,ETH-PERPETUAL
