PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:4200,http://localhost:3001

# Polymarket - RTDS
POLYMARKET_RTDS_URL=wss://ws-live-data.polymarket.com

# Polymarket - CLOB WebSocket
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Polymarket - REST APIs
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com

# Default subscriptions (comma-separated, loaded at startup)
POLYMARKET_DEFAULT_CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT
