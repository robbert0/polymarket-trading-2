PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:4200,http://localhost:3001

# Polymarket - RTDS
POLYMARKET_RTDS_URL=wss://ws-live-data.polymarket.com

# Polymarket - CLOB WebSocket
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Polymarket - REST APIs
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com

# Default subscriptions (comma-separated, loaded at startup)
POLYMARKET_DEFAULT_CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT

# Edge detection — trade advice tuning
# Minimum absolute probability gap between Deribit and Polymarket
# needed to emit BUY_YES / BUY_NO advice. 0.08 = 8%.
ARBITRAGE_EDGE_THRESHOLD=0.08

# How often (ms) to REST-refresh Polymarket orderbooks as a safety net
# for missed CLOB WebSocket book updates.
BOOK_REFRESH_MS=10000

# Trailing-edge throttle (ms) per market for edge recalculation after
# CLOB book updates. Prevents bursty orderbook deltas from flooding
# the SSE stream.
BOOK_THROTTLE_MS=500

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Deribit
DERIBIT_WS_URL=wss://www.deribit.com/ws/api/v2
DERIBIT_INSTRUMENTS=BTC-PERPETUAL,ETH-PERPETUAL

# Postgres — orders/executions audit trail
# docker-compose maps host 5433 → container 5432 (host 5432 is often the
# user's local postgres). Override POSTGRES_PORT if you're using your own
# postgres instance on a different port.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket
POSTGRES_DB=polymarket

# Trading — mode
# 'paper' (default, no real orders) or 'live' (places real orders on Polymarket CLOB)
TRADING_MODE=paper
# Master kill-switch. If 'false', edge signals are NOT enqueued.
TRADING_ENABLED=true

# Polymarket credentials — ONLY required when TRADING_MODE=live
# L2 credentials can be derived from POLYMARKET_PRIVATE_KEY via the derive-api-key script.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
# EIP-712 signature type: 0=EOA (default), 1=MAGIC_LINK, 2=PROXY_WALLET
POLYMARKET_SIGNATURE_TYPE=0
# Neg-risk adapter toggle. For single-outcome BTC markets: false.
POLYMARKET_NEG_RISK=false

# Trading — sizing (phase 1: fixed size)
TRADING_FIXED_ORDER_SIZE_USD=10
TRADING_MAX_ORDER_SIZE_USD=50

# Trading — risk limits
TRADING_MAX_OPEN_POSITIONS=5
TRADING_MAX_TOTAL_NOTIONAL_USD=200
# Do not enter a market that expires within X hours. 0.5 = 30 min.
TRADING_MIN_HOURS_TO_EXPIRY=0.5
# Cooldown (seconds) per market after a reject/fail before we accept new intents.
TRADING_MARKET_COOLDOWN_SEC=60

# Trading — signal filters (stricter than the general ARBITRAGE_EDGE_THRESHOLD)
# Minimum edge AFTER crossing the spread. Must be strictly positive.
TRADING_MIN_EXECUTABLE_EDGE=0.02
# Minimum fill-score (0-100). Orderbook must have enough liquidity.
TRADING_MIN_FILL_SCORE=60
# Minimum fillable depth in USD within slippage range.
TRADING_MIN_FILLABLE_USD=50

# Trading — slippage (FAK orders)
# Maximum accepted slippage vs refPrice. 0.03 = 3%.
TRADING_MAX_SLIPPAGE_PCT=0.03

# Trading — bankroll cache (live-mode wallet state, cached for zero-latency orders)
# How often (ms) the CLOB wallet is polled for USDC + open conditional tokens.
TRADING_BANKROLL_REFRESH_MS=300000
# Max accepted staleness of cache at order-check time.
TRADING_BANKROLL_MAX_STALE_MS=900000
# Block new orders when cache is stale and cannot refresh? true = safe, false = best-effort.
TRADING_BANKROLL_STALE_BLOCK=true
# Paper mode: virtual bankroll ceiling in USD. Used for MAX_TOTAL_NOTIONAL check.
TRADING_PAPER_BANKROLL_USD=500

# Trading — exit logic (Phase 4)
# Close a position when the mark drops by this pct from avgEntry (0.25 = -25%).
TRADING_EXIT_STOP_LOSS_PCT=0.25
# Take profit when mark rises by this pct from avgEntry (must stay < 1).
TRADING_EXIT_TAKE_PROFIT_PCT=0.4
# Close when executableEdge has flipped against the position by this amount.
TRADING_EXIT_REVERSAL_EDGE=0.02
# Flatten any open position within this many hours of market expiry.
TRADING_EXIT_FLATTEN_HOURS=0.25
# Cooldown between auto-exit attempts on the same position (seconds).
TRADING_EXIT_COOLDOWN_SEC=30
